rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /slugs/{slug} {
      allow read: if true;
      allow write: if false; // Only server can write
    }

    match /project-slugs/{projectSlug} {
      allow read: if true;
      allow write: if false; // Only server can write
    }

    // Users can read/write their own user document and subcollections
    match /users/{user}/{document=**} {
      allow read, write: if request.auth.uid == user
    }

    // Organizations: members can read, owners/admins can write
    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if request.auth != null;
      allow update, delete: if isOrgAdmin(orgId);

      // Org members subcollection
      match /members/{memberId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgAdmin(orgId);
      }

      // Org invitations
      match /invitations/{invitationId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgAdmin(orgId);
        allow update: if isOrgAdmin(orgId) || request.auth != null;
        allow delete: if isOrgAdmin(orgId);
      }

      // Org billing: only owners can read/write
      match /billing/{document=**} {
        allow read: if isOrgOwner(orgId);
        allow write: if false; // billing is managed server-side only
      }
    }

    // Projects: check direct membership, org membership, or public visibility
    match /projects/{project} {
      allow read: if isProjectMember(project) || isProjectPublic(project);
      allow write: if isProjectMember(project);

      match /{document=**} {
        allow read: if isProjectMember(project) || isProjectPublic(project);
        allow write: if isProjectMember(project);
      }
    }

    // API keys collection (server-managed, no direct client access)
    match /keys/{keyId} {
      allow read, write: if false;
    }

    // Helper functions
    function isOrgMember(orgId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    function isOrgAdmin(orgId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    function isOrgOwner(orgId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role == 'owner';
    }

    function isProjectMember(project) {
      return request.auth != null &&
        get(/databases/$(database)/documents/projects/$(project)).data.members[request.auth.uid] is string;
    }

    function isProjectPublic(project) {
      return get(/databases/$(database)/documents/projects/$(project)).data.visibility == 'public';
    }
  }
}

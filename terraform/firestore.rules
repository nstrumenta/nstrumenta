rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /slugs/{slug} {
      allow read: if true;
      allow write: if false; // Only server can write
    }

    // Users can read their own user document; all writes go through server API
    match /users/{user} {
      allow read: if request.auth.uid == user;
      allow write: if false;

      match /notifications/{notificationId} {
        allow read: if request.auth.uid == user;
        allow write: if false;
      }
    }

    // Organizations: all writes go through server API (Admin SDK bypasses rules)
    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow write: if false;

      match /members/{memberId} {
        allow read: if isOrgMember(orgId);
        allow write: if false;
      }

      match /invitations/{invitationId} {
        allow read: if isOrgMember(orgId);
        allow write: if false;
      }

      match /billing/{document=**} {
        allow read: if isOrgOwner(orgId);
        allow write: if false;
      }

      // Project doc is server-managed; subcollections are written directly by clients
      match /projects/{projectId} {
        allow read: if isOrgMember(orgId) || isOrgProjectPublic(orgId, projectId);
        allow write: if false;

        match /githubConnections/{installationId} {
          allow read: if isOrgMember(orgId);
          allow write: if false;
        }

        match /githubLinks/{linkId} {
          allow read: if isOrgMember(orgId);
          allow write: if false;
        }

        match /modules/{moduleId} {
          allow read: if isOrgMember(orgId) || isOrgProjectPublic(orgId, projectId);
          // Prevent non-admins from spoofing approval state flags
          allow write: if isOrgMember(orgId) && (
            !(request.resource.data.keys().hasAny(['approved', 'approvedAt', 'approvedBy'])) || 
            isOrgAdmin(orgId)
          );
        }

        // We use a wildcard but we must explicitly exclude writing 'modules' since the more permissive rule acts as an OR
        // However, firestore doesn't allow excluding collection names in deep wildcards cleanly if multiple matches exist.
        // Let's rely on capturing the root subcollection:
        match /{collection}/{document=**} {
          allow read: if isOrgMember(orgId) || isOrgProjectPublic(orgId, projectId);
          allow write: if isOrgMember(orgId) && (
            collection != 'modules' || 
            (
               !("approved" in request.resource.data) && !("approvedAt" in request.resource.data) && !("approvedBy" in request.resource.data)
            ) || 
            isOrgAdmin(orgId)
          );
        }
      }
    }

    // API keys collection (server-managed, no direct client access)
    match /keys/{keyId} {
      allow read, write: if false;
    }

    // Helper functions
    function isOrgMember(orgId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    function isOrgAdmin(orgId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    function isOrgOwner(orgId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role == 'owner';
    }

    function isOrgProjectPublic(orgId, projectId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/projects/$(projectId)).data.visibility == 'public';
    }

  }
}

{
  "name": "nst-server",
  "version": "4.2.5",
  "description": "server for nstrumenta",
  "bin": {
    "nst-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "npx tsc -p .",
    "typecheck": "npx tsc --noEmit -p .",
    "format": "prettier -w ./src",
    "dev-dotenv": "dotenv -e $ENVFILE -- bash -c 'env && npm run dev'",
    "dev": "tsx watch --inspect=0.0.0.0:9229 src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Tyler Bryant",
  "license": "UNLICENSED",
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "@google-cloud/run": "^3.2.0",
    "@google-cloud/storage": "^7.19.0",
    "google-auth-library": "^9.15.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "firebase-admin": "^13.7.0",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@tsconfig/node16": "^16.1.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "prettier": {
    "trailingComma": "all",
    "tabWidth": 2,
    "useTabs": false,
    "semi": false,
    "singleQuote": true,
    "preferTemplate": true
  }
}
